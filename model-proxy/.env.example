# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set to "true" to enforce JWT auth on every request.
# When false, requests are passed through without any auth check.
AUTH_ENABLED=true

# Secret (or PEM public key) used to verify incoming JWT tokens.
# For HMAC algorithms (HS256/HS384/HS512) this is the shared secret.
# For RSA/EC algorithms (RS256, ES256 …) paste the PEM public key here
# or point JWT_PUBLIC_KEY_FILE at a file path.
JWT_SECRET=change-me-in-production
# JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public.pem

# JWT verification options (comma-separated accepted algorithms)
JWT_ALGORITHMS=HS256

# ─── Session cache ────────────────────────────────────────────────────────────
# How long (seconds) a decoded JWT payload is cached in memory.
# Set to 0 to disable caching (decode on every request).
SESSION_TTL_SECONDS=300

# Maximum number of sessions kept in the in-memory cache.
SESSION_MAX_ENTRIES=1000

# ─── Model → Ollama instance routing ─────────────────────────────────────────
# Format: MODEL_ROUTE_<UPPERCASE_MODEL_NAME>=<base URL of the Ollama instance>
# Model names are normalised to uppercase for lookup, so
# MODEL_ROUTE_LLAMA3 matches requests for "llama3", "Llama3", etc.
#
# A colon-separated alias list can map multiple names to the same host:
#   MODEL_ROUTE_LLAMA3:LLAMA3.2:LLAMA3.1=http://gpu-1:11434
#
MODEL_ROUTE_LLAMA3=http://ollama-gpu-1:11434
MODEL_ROUTE_MISTRAL=http://ollama-gpu-2:11434
MODEL_ROUTE_CODELLAMA=http://ollama-gpu-3:11434

# Fallback: used when no specific route is matched.
MODEL_ROUTE_DEFAULT=http://ollama-default:11434

# ─── Proxy behaviour ──────────────────────────────────────────────────────────
# Maximum size of a request body that will be buffered (express limit string).
BODY_LIMIT=50mb

# Forward the original Host header to the upstream Ollama instance.
PROXY_PRESERVE_HOST=false
